#!/bin/bash

# Source zsh config in a zsh subshell to get env vars, then export them to this bash shell
if [ -f ~/.zshrc ]; then
  eval "$(zsh -c 'source ~/.zshrc 2>/dev/null; printf "export JFROG_READ_USER=%s JFROG_READ_TOKEN=%s\n" "$JFROG_READ_USER" "$JFROG_READ_TOKEN"')"
fi

if [ -n "$1" ] && [ "$1" = "pre_commit_all_files" ] ; then
  PRE_COMMIT_ALL_FILES=true
  echo "PRE_COMMIT_ALL_FILES is set"
else
  PRE_COMMIT_ALL_FILES=false
  echo "PRE_COMMIT_ALL_FILES is NOT set"
fi

GIT_PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_PROJECT_ROOT" || exit
# Validate JFrog credentials are set
if [ -z "$JFROG_READ_USER" ] || [ -z "$JFROG_READ_TOKEN" ]; then
  echo "ERROR: JFROG_READ_USER and JFROG_READ_TOKEN must be set in the environment." >&2
  exit 1
fi
export DOCKER_BUILDKIT=1 && \
docker build \
  --secret id=jfrog_user,env=JFROG_READ_USER \
  --secret id=jfrog_token,env=JFROG_READ_TOKEN \
  -f ./pre-commit.Dockerfile -t pre-commit-languagemodelcommon . && \
docker run --rm --name pre-commit-run-languagemodelcommon -e PRE_COMMIT_ALL_FILES=$PRE_COMMIT_ALL_FILES -v pre-commit:/.cache/pre-commit:delegated -v "$(pwd)"/:/sourcecode pre-commit-languagemodelcommon
